# 数据库配置
DB_HOST=127.0.0.1
DB_PORT=3307
DB_USER=root
DB_PASSWORD=123456
DB_DATABASE=jabobo
DB_CHARSET=utf8mb4
DB_AUTOCOMMIT=true

# 豆包 API 核心配置（必须配置，无默认）
ARK_API_KEY=129f510f-f857-4755-8324-dd5d8e29a635
ARK_EMBED_MODEL=doubao-embedding-text-240715
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3

# 文本切分配置（必须配置，无默认）
CHUNK_MAX_CHARS=500
CHUNK_OVERLAP=100

# 检索配置（必须配置，无默认）
TOP_K=5
SIMILARITY_THRESHOLD=0.7

# 分批处理配置（必须配置，无默认）
BATCH_SIZE=20